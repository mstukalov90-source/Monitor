# MSI Holes API (genplan_fetch at 05:00)
# Optional if genplan api/msi-holes-backend.client.json exists (used as fallback)
MSI_HOLES_CLIENT_ID=
MSI_HOLES_CLIENT_SECRET=
MSI_HOLES_BASE_URL=https://m2m.msi-holes.cxm.dev
MSI_HOLES_TOKEN_ENDPOINT=https://id.cxm.dev/oauth2/token
GENPLAN_SEARCH_LAT=55.7558
GENPLAN_SEARCH_LNG=37.6173
GENPLAN_SEARCH_RADIUS_M=20000
# Local smoke test: limit meta fetches (0 = no limit in production)
GENPLAN_FETCH_META_LIMIT=0
# Limit meta fetches for uploaded photos per run (0 = no limit)
GENPLAN_FETCH_UPLOADED_LIMIT=0

# MONITOR M2M API (photo meta ingest)
# Public base URL for colleagues (no domain — VPS IP + port)
MONITOR_API_PUBLIC_BASE_URL=http://77.222.63.161:8000
# 256-bit API key: 64 hex chars. Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
MONITOR_API_KEY=
# Optional comma-separated keys for multiple organizations
MONITOR_API_KEYS=
MONITOR_API_PORT=8000
# On VPS open port 8000 only for trusted IPs, e.g.:
#   ufw allow from <colleague_ip> to any port 8000 proto tcp

# Timezone for cron schedule
TZ=Europe/Moscow

# Security: restrict port 5432 on the VPS firewall to trusted IPs when possible:
#   ufw allow from <your_ip> to any port 5432 proto tcp
